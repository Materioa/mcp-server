{
  "openapi": "3.1.0",
  "info": {
    "title": "Materio MCP",
    "description": "Professional access to the Materio document library and semantic knowledge base. Features priority semantic search (RAG) and direct document retrieval.",
    "version": "2.1.1"
  },
  "paths": {
    "/search": {
      "post": {
        "summary": "Step 1: Perform semantic RAG search across the Materio library.",
        "description": "Primary tool for answering user questions. Returns relevant text chunks with source metadata.",
        "operationId": "search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "The natural language question."
                  },
                  "semester": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 5
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns relevant chunks and source info."
          }
        }
      }
    },
    "/fetch_pdf": {
      "post": {
        "summary": "Step 2: Fallback direct document fetch.",
        "description": "Retrieves raw content if semantic search results are insufficient or if the user requests a deep dive into a specific PDF.",
        "operationId": "fetch_pdf",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "semester": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "topic": {
                    "type": "string"
                  },
                  "filetype": {
                    "type": "string",
                    "enum": [
                      "pdf",
                      "docx"
                    ],
                    "default": "pdf"
                  }
                },
                "required": [
                  "semester",
                  "subject",
                  "topic"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns raw status and size."
          }
        }
      }
    },
    "/get_resource": {
      "get": {
        "summary": "Search the library file tree for study materials by name.",
        "operationId": "get_resource",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "semester",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subject",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns a list of matching resources."
          }
        }
      }
    },
    "/list_resources": {
      "get": {
        "summary": "Get an overview of available semesters and subjects.",
        "operationId": "list_resources",
        "responses": {
          "200": {
            "description": "Returns a JSON hierarchy of the library."
          }
        }
      }
    },
    "/share_link": {
      "post": {
        "summary": "Generate a masked share link for any raw URL.",
        "operationId": "share_link",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns a masked share link string."
          }
        }
      }
    }
  }
}