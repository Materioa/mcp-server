{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "routes": [
    {
      "src": "/mcp",
      "dest": "/api/mcp.js"
    },
    {
      "src": "/api/mcp",
      "dest": "/api/mcp.js"
    }
  ],
  "functions": {
    "api/mcp.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
